#!/usr/bin/env bash
# Bundled ShipFlow CLI launcher — ships inside the plugin, so users don't need a
# separate `npm i -g @renaiss-shipflow/cli`. Requires node, gh, and git on PATH.
#
# Resolves the NEWEST installed plugin version's bundled CLI, so the CLI tracks
# the latest cached version even when an older launcher symlink is still on PATH.
# (Without this, a symlink created in an early session strands the CLI on a stale
# version forever — the bug behind "plugin updated but CLI is still old".)
set -euo pipefail

_newest="$(ls -d "$HOME"/.claude/plugins/cache/renaissshipflow/shipflow/*/cli/dist/renaiss-shipflow.mjs 2>/dev/null | sort -V | tail -1)"
if [ -z "${_newest:-}" ]; then
  # Fallback: the CLI co-located with this launcher.
  DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  _newest="$DIR/../cli/dist/renaiss-shipflow.mjs"
fi
exec node "$_newest" "$@"
